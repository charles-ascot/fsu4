# ── Chimera FSU: fsu4 ───────────────────────────────────────────────────────────
# This file documents required secrets. DO NOT put real values here.
# ALL credentials are loaded from Google Secret Manager at runtime.
# No environment variables containing secrets are used in production.

# GCP project — set automatically on Cloud Run via metadata server.
# Only needed for local development.
GOOGLE_CLOUD_PROJECT=chimera

# ── Secrets that must exist in Google Secret Manager ─────────────────────────
# These are loaded by app/core/secrets.py at runtime.
#
# Secret ID: anthropic-api-key
#   Value:   Your Anthropic API key (sk-ant-...)
#
# Secret ID: chimera-api-key
#   Value:   The X-Chimera-API-Key header value for this FSU
#
# Secret ID: gmail-oauth-credentials
#   Value:   JSON object: {"client_id": "...", "client_secret": "...", "token_uri": "..."}
#
# Secret ID: gmail-token
#   Value:   JSON object: {"token": "...", "refresh_token": "...", "token_uri": "..."}
#
# ── Local development only ────────────────────────────────────────────────────
# To run locally, authenticate with: gcloud auth application-default login
# Then set GOOGLE_CLOUD_PROJECT=chimera and ensure your account has
# Secret Manager Secret Accessor role on the chimera project.
